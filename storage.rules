rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function signedIn() {
      return request.auth != null;
    }

    function verifiedOwner(uid) {
      return signedIn()
        && request.auth.uid == uid
        && request.auth.token.email_verified == true;
    }

    function isAllowedUpload(maxSize) {
      return request.resource.size < maxSize
        && (
          request.resource.contentType.matches('image/.*')
          || request.resource.contentType == 'application/pdf'
          || request.resource.contentType == 'text/plain'
        );
    }

    match /pilot-attachments/{uid}/{fileName} {
      allow create: if verifiedOwner(uid) && isAllowedUpload(5 * 1024 * 1024);
      allow read: if verifiedOwner(uid);
      allow update, delete: if false;
    }

    match /intake-documents/{uid}/{fileName} {
      allow create: if verifiedOwner(uid) && isAllowedUpload(10 * 1024 * 1024);
      allow read: if verifiedOwner(uid);
      allow update, delete: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
