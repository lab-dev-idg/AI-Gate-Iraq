rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function signedIn() {
      return request.auth != null;
    }

    function isAllowedUpload(maxSize) {
      return request.resource.size < maxSize
        && (
          request.resource.contentType.matches('image/.*')
          || request.resource.contentType == 'application/pdf'
          || request.resource.contentType == 'text/plain'
        );
    }

    match /pilot-attachments/{fileName} {
      allow create: if signedIn() && isAllowedUpload(5 * 1024 * 1024);
      allow read: if signedIn();
      allow update, delete: if false;
    }

    match /intake-documents/{fileName} {
      allow create: if signedIn() && isAllowedUpload(10 * 1024 * 1024);
      allow read: if signedIn();
      allow update, delete: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
