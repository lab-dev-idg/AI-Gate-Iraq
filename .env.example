GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
NODE_ENV=development
PORT=3000

# Firebase Dynamic Web App Config
VITE_FIREBASE_API_KEY=your_new_firebase_web_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_new_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_new_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_new_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_web_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id_optional

# Public payment API origin. Leave empty until the Worker is configured and live.
VITE_PAYMENT_API_BASE_URL=https://api.example.com

# Firebase App Check (reCAPTCHA Enterprise site key; public web identifier)
VITE_RECAPTCHA_ENTERPRISE_SITE_KEY=your_recaptcha_enterprise_site_key

# Firebase Admin
FIREBASE_PROJECT_ID=your_new_project_id
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/firebase-admin-service-account.json

# Cloudflare Worker payment configuration. Store secret values with `wrangler secret put`.
FIREBASE_WEB_API_KEY=your_firebase_web_api_key
FIREBASE_SERVICE_ACCOUNT_EMAIL=service-account@project.iam.gserviceaccount.com
FIREBASE_SERVICE_ACCOUNT_PRIVATE_KEY=replace_with_service_account_private_key
PAYMENT_PUBLIC_BASE_URL=https://api.example.com
PAYMENT_PRO_AMOUNT_IQD=replace_with_merchant_price
PAYMENT_PRO_DURATION_DAYS=30
ZAINCASH_API_BASE_URL=https://pg-api-uat.zaincash.iq
ZAINCASH_CLIENT_ID=replace_with_zaincash_client_id
ZAINCASH_CLIENT_SECRET=replace_with_zaincash_client_secret
ZAINCASH_API_SECRET=replace_with_zaincash_api_secret
ZAINCASH_SERVICE_TYPE=AI_GATE_IRAQ_PRO

# Conversion Security
CONVERSION_FINGERPRINT_SECRET=replace_with_a_long_random_secret
ADMIN_SESSION_MAX_AGE_MINUTES=60

# Conversion Notifications
CONVERSION_NOTIFICATION_WEBHOOK_URL=
CONVERSION_NOTIFICATION_WEBHOOK_SECRET=replace_with_a_long_random_secret
CONVERSION_NOTIFICATION_TIMEOUT_MS=5000
