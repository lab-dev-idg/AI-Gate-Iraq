rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/adminUsers/$(request.auth.uid));
    }

    function isStringField(fieldName, maxLen) {
      return request.resource.data[fieldName] is string
        && request.resource.data[fieldName].size() > 0
        && request.resource.data[fieldName].size() <= maxLen;
    }

    function validPublicIntakeCreate() {
      return request.resource.data.keys().hasOnly([
        'id',
        'name',
        'company',
        'contact',
        'serviceInterest',
        'category',
        'message',
        'status',
        'createdAt',
        'updatedAt'
      ])
      && request.resource.data.status == 'new'
      && isStringField('name', 120)
      && isStringField('contact', 160)
      && isStringField('serviceInterest', 120)
      && isStringField('message', 2500);
    }

    match /adminUsers/{uid} {
      allow read: if isAdmin() || (signedIn() && request.auth.uid == uid);
      allow create, update, delete: if false;
    }

    match /adminConfig/global {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    match /featureFlags/{flagKey} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    match /serviceConfigs/{serviceKey} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    match /promptConfigs/{promptId} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    match /workflowSteps/{stepId} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    match /contentSections/{sectionId} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    match /intakeItems/{intakeId} {
      allow create: if validPublicIntakeCreate();
      allow read, update: if isAdmin();
      allow delete: if false;
    }

    match /auditLogs/{logId} {
      allow create, read: if isAdmin();
      allow update, delete: if false;
    }

    match /pilotAttachments/{attachmentId} {
      allow create, read: if isAdmin();
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
