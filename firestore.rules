rules_version = '2';
// Admin access rules deploy with every Firebase platform release.
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function verifiedSignedIn() {
      return signedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isVerifiedOwner(uid) {
      return verifiedSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/adminUsers/$(request.auth.uid))
        && get(/databases/$(database)/documents/adminUsers/$(request.auth.uid)).data.active == true
        && get(/databases/$(database)/documents/adminUsers/$(request.auth.uid)).data.role in ['owner', 'admin'];
    }

    function hasActiveProSubscription(uid) {
      return exists(/databases/$(database)/documents/subscriptions/$(uid))
        && get(/databases/$(database)/documents/subscriptions/$(uid)).data.plan == 'pro'
        && get(/databases/$(database)/documents/subscriptions/$(uid)).data.status == 'active'
        && get(/databases/$(database)/documents/subscriptions/$(uid)).data.currentPeriodEnd is timestamp
        && get(/databases/$(database)/documents/subscriptions/$(uid)).data.currentPeriodEnd > request.time;
    }

    function isStringField(fieldName, maxLen) {
      return request.resource.data[fieldName] is string
        && request.resource.data[fieldName].size() > 0
        && request.resource.data[fieldName].size() <= maxLen;
    }

    function isOptionalStringField(fieldName, maxLen) {
      return !request.resource.data.keys().hasAny([fieldName])
        || (
          request.resource.data[fieldName] is string
          && request.resource.data[fieldName].size() <= maxLen
        );
    }

    function validPublicConversionCreate() {
      return request.resource.data.keys().hasOnly([
        'type', 'language', 'fullName', 'email', 'phone',
        'organization', 'role', 'country', 'city', 'service',
        'message', 'consent', 'sourceUrl', 'website', 'status',
        'createdAt', 'updatedAt'
      ])
      && request.resource.data.keys().hasAll([
        'type', 'language', 'fullName', 'email', 'phone',
        'organization', 'country', 'service', 'message',
        'consent', 'sourceUrl', 'website', 'status',
        'createdAt', 'updatedAt'
      ])
      && request.resource.data.type in ['demo', 'pilot', 'contact']
      && request.resource.data.language in ['ku', 'ar', 'en']
      && request.resource.data.status == 'received'
      && request.resource.data.consent == true
      && request.resource.data.website == ''
      && request.resource.data.country == 'Iraq'
      && isStringField('fullName', 100)
      && isStringField('email', 160)
      && isStringField('phone', 32)
      && isStringField('organization', 120)
      && isStringField('service', 100)
      && isStringField('message', 1800)
      && isStringField('sourceUrl', 500)
      && isOptionalStringField('role', 100)
      && isOptionalStringField('city', 100)
      && request.resource.data.createdAt is timestamp
      && request.resource.data.updatedAt is timestamp;
    }

    function validAdminConversionUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'status', 'adminNote', 'assignedTo', 'updatedAt'
      ])
      && (
        !request.resource.data.keys().hasAny(['status'])
        || request.resource.data.status in [
          'received', 'contacted', 'qualified', 'converted', 'closed'
        ]
      )
      && isOptionalStringField('adminNote', 4000)
      && isOptionalStringField('assignedTo', 160)
      && request.resource.data.updatedAt is timestamp;
    }

    function validPublicIntakeCreate() {
      return request.resource.data.keys().hasOnly([
        'id', 'name', 'company', 'contact', 'serviceInterest',
        'category', 'message', 'status', 'createdAt', 'updatedAt'
      ])
      && request.resource.data.status == 'new'
      && isStringField('name', 120)
      && isStringField('contact', 160)
      && isStringField('serviceInterest', 120)
      && isStringField('message', 2500);
    }

    function validWorkspaceWrite(uid) {
      return isOwner(uid)
        && request.resource.data.keys().hasOnly([
          'ownerUid', 'session', 'updatedAtMs', 'updatedAt', 'schemaVersion'
        ])
        && request.resource.data.ownerUid == uid
        && request.resource.data.schemaVersion == 1
        && request.resource.data.updatedAtMs is int
        && request.resource.data.session is map;
    }

    function validUsageCreate(uid) {
      return request.resource.data.keys().hasOnly([
        'uid', 'questionsUsed', 'lastPlan', 'createdAt', 'updatedAt'
      ])
      && request.resource.data.keys().hasAll([
        'uid', 'questionsUsed', 'lastPlan', 'createdAt', 'updatedAt'
      ])
      && request.resource.data.uid == uid
      && request.resource.data.questionsUsed == 1
      && request.resource.data.lastPlan in ['free', 'pro']
      && request.resource.data.createdAt == request.time
      && request.resource.data.updatedAt == request.time;
    }

    function validUsageIncrement(uid) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'questionsUsed', 'lastPlan', 'updatedAt'
      ])
      && request.resource.data.uid == uid
      && request.resource.data.questionsUsed == resource.data.questionsUsed + 1
      && request.resource.data.lastPlan in ['free', 'pro']
      && request.resource.data.updatedAt == request.time
      && (hasActiveProSubscription(uid) || resource.data.questionsUsed < 3);
    }

    function validSubscriptionRequest(uid) {
      return request.resource.data.keys().hasOnly([
        'uid', 'email', 'displayName', 'requestedPlan', 'status',
        'createdAt', 'updatedAt', 'adminNote', 'resolvedAt', 'resolvedBy'
      ])
      && request.resource.data.uid == uid
      && request.resource.data.requestedPlan == 'pro'
      && request.resource.data.status == 'pending'
      && request.resource.data.email is string
      && request.resource.data.email.size() <= 160
      && request.resource.data.displayName is string
      && request.resource.data.displayName.size() <= 160
      && request.resource.data.updatedAt == request.time;
    }

    function validPaymentOrderCreate(orderId) {
      return verifiedSignedIn()
      && request.resource.data.keys().hasOnly([
        'orderId', 'uid', 'email', 'provider', 'plan', 'amount', 'currency',
        'durationDays', 'status', 'externalReferenceId', 'providerTransactionId',
        'createdAt', 'updatedAt'
      ])
      && request.resource.data.keys().hasAll([
        'orderId', 'uid', 'email', 'provider', 'plan', 'amount', 'currency',
        'durationDays', 'status', 'externalReferenceId', 'providerTransactionId',
        'createdAt', 'updatedAt'
      ])
      && request.resource.data.orderId == orderId
      && request.resource.data.uid == request.auth.uid
      && request.resource.data.email == request.auth.token.email
      && request.resource.data.provider == 'zaincash'
      && request.resource.data.plan == 'pro'
      && request.resource.data.amount is int
      && request.resource.data.amount > 0
      && request.resource.data.currency == 'IQD'
      && request.resource.data.durationDays is int
      && request.resource.data.durationDays > 0
      && request.resource.data.durationDays <= 366
      && request.resource.data.status == 'pending'
      && request.resource.data.externalReferenceId is string
      && request.resource.data.externalReferenceId.size() == 36
      && request.resource.data.providerTransactionId is string
      && request.resource.data.providerTransactionId.size() > 0
      && request.resource.data.providerTransactionId.size() <= 160
      && request.resource.data.createdAt == request.time
      && request.resource.data.updatedAt == request.time;
    }

    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create, update: if isOwner(uid);
      allow delete: if false;

      match /workspace/{workspaceId} {
        allow read: if isVerifiedOwner(uid);
        allow create, update: if isVerifiedOwner(uid) && validWorkspaceWrite(uid);
        allow delete: if false;
      }

      match /conversations/{conversationId} {
        allow read, create, update: if isVerifiedOwner(uid);
        allow delete: if isVerifiedOwner(uid);
      }

      match /drafts/{draftId} {
        allow read, create, update, delete: if isVerifiedOwner(uid);
      }

      match /shipments/{shipmentId} {
        allow read: if isVerifiedOwner(uid);
        allow create, update: if isVerifiedOwner(uid);
        allow delete: if false;
      }
    }

    match /subscriptions/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    match /usageCounters/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isAdmin() || (isOwner(uid) && validUsageCreate(uid));
      allow update: if isAdmin() || (isOwner(uid) && validUsageIncrement(uid));
      allow delete: if false;
    }

    match /subscriptionRequests/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isAdmin() || (isOwner(uid) && validSubscriptionRequest(uid));
      allow update: if isAdmin() || (
        isOwner(uid)
        && validSubscriptionRequest(uid)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'email', 'displayName', 'requestedPlan', 'status', 'updatedAt'
        ])
      );
      allow delete: if false;
    }

    match /paymentOrders/{orderId} {
      allow read: if isAdmin() || (
        signedIn()
        && resource.data.uid == request.auth.uid
      );
      allow create: if validPaymentOrderCreate(orderId);
      allow update, delete: if false;
    }

    match /paymentEvents/{eventId} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    match /adminUsers/{uid} {
      allow read: if isAdmin() || isOwner(uid);
      allow create, update, delete: if false;
    }

    match /adminConfig/global {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    match /featureFlags/{flagKey} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    match /serviceConfigs/{serviceKey} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    match /promptConfigs/{promptId} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    match /workflowSteps/{stepId} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    match /contentSections/{sectionId} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    match /intakeItems/{intakeId} {
      allow create: if validPublicIntakeCreate();
      allow read, update: if isAdmin();
      allow delete: if false;
    }

    match /conversionSubmissions/{submissionId} {
      allow create: if validPublicConversionCreate();
      allow read: if isAdmin();
      allow update: if isAdmin() && validAdminConversionUpdate();
      allow delete: if false;
    }

    match /auditLogs/{logId} {
      allow create, read: if isAdmin();
      allow update, delete: if false;
    }

    match /attachments/{attachmentId} {
      allow create, read: if isAdmin();
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
