rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default fallback: Block all access to prevent open database vulnerabilities
    match /{document=**} {
      allow read, write: if false;
    }

    // 1. adminConfig (Store configuration overrides)
    match /adminConfig/global {
      allow read: if true; // Public must read customized brand headers
      allow write: if request.auth != null; // TODO: Implement request.auth.token.isAdmin == true for production RBAC
    }

    // 2. featureFlags
    match /featureFlags/{flagKey} {
      allow read: if true; // Public reads toggles dynamically
      allow write: if request.auth != null; // TODO: Restrict config writes strictly to Admins
    }

    // 3. serviceConfigs
    match /serviceConfigs/{serviceKey} {
      allow read: if true;
      allow write: if request.auth != null; // TODO: Restrict edits strictly to Admins
    }

    // 4. promptConfigs
    match /promptConfigs/{promptId} {
      allow read: if true;
      allow write: if request.auth != null; // TODO: Restrict edits strictly to Admins
    }

    // 5. workflowSteps
    match /workflowSteps/{stepId} {
      allow read: if true;
      allow write: if request.auth != null; // TODO: Restrict edits strictly to Admins
    }

    // 6. contentSections
    match /contentSections/{sectionId} {
      allow read: if true;
      allow write: if request.auth != null; // TODO: Restrict edits strictly to Admins
    }

    // 7. intakeItems (Dynamic Public Inquiries)
    match /intakeItems/{intakeId} {
      // Allow general public to submit forms without auth, but enforce 'new' status
      allow create: if request.resource.data.status == 'new';
      // Restrict read and write/update capabilities completely to Authed Admins
      allow read, update: if request.auth != null; // TODO: Implement request.auth.token.isAdmin == true
      allow delete: if false; // Deny general deletes
    }

    // 8. auditLogs (Administrative auditable changes log)
    match /auditLogs/{logId} {
      // System writes on admin edits or authed actions
      allow create: if request.auth != null;
      // Admins read
      allow read: if request.auth != null; // TODO: Implement request.auth.token.isAdmin == true
      allow update, delete: if false; // Immutable logs
    }

    // 9. pilotAttachments
    match /pilotAttachments/{attachmentId} {
      allow create, read: if request.auth != null;
    }
  }
}
